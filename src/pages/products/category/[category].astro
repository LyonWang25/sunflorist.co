---
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import PageHead from '../../../components/PageHead.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { categories, type Category } from '../../../data/categories';
import { breadcrumbJsonLd } from '../../../data/jsonld';
import { categoryImage } from '../../../utils/images';
import { productImage } from '../../../utils/images';
import { getProducts } from '../../../utils/products';

export async function getStaticPaths() {
  return categories.map((cat) => ({ params: { category: cat.slug }, props: { cat } }));
}

interface Props {
  cat: Category;
}

const { cat } = Astro.props;
const products = cat.consultationOnly ? [] : await getProducts(cat.slug);

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Collections', path: '/products/' },
  { name: cat.name },
];
---

<Base
  title={`${cat.name} | Sun Florist`}
  description={`${cat.intro} Sun Florist — serving DC, MD, VA and NC.`}
  ogImage="/og/collections.jpg"
  jsonLd={breadcrumbJsonLd(crumbs)}
>
  <Nav current={cat.slug === 'wedding-events' ? 'weddings' : 'collections'} />
  <main>
    <PageHead {crumbs} title={cat.name} lede={cat.consultationOnly ? undefined : cat.intro} />

    {
      cat.consultationOnly ? (
        <div class="container consult">
          {
            cat.heroVideo ? (
              <div class="consult-media consult-media--video">
                <video
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  poster={cat.heroVideo.poster}
                  width={cat.heroVideo.width}
                  height={cat.heroVideo.height}
                  aria-label={cat.coverAlt}
                >
                  <source src={cat.heroVideo.webm} type="video/webm" />
                  <source src={cat.heroVideo.mp4} type="video/mp4" />
                </video>
              </div>
            ) : (
              <div class="consult-media">
                <Image
                  src={categoryImage(cat.cover)}
                  widths={[640, 1024, 1600]}
                  sizes="(max-width: 767px) 100vw, 920px"
                  format="webp"
                  quality={75}
                  alt={cat.coverAlt}
                  loading="eager"
                  decoding="async"
                />
              </div>
            )
          }
          <p class="consult-intro">{cat.intro}</p>
          <ol class="how-steps">
            <li>
              <span class="roman">i.</span> Let's meet
            </li>
            <li>
              <span class="roman">ii.</span> Plan &amp; design
            </li>
            <li>
              <span class="roman">iii.</span> We style the day
            </li>
          </ol>
          <a class="btn" href="/contact/">
            Start a consultation
          </a>
        </div>
      ) : (
        <div class="container">
          <div class="product-grid">
            {products.map((product, i) => (
              <ProductCard
                name={product.data.name}
                href={`/products/${product.data.slug}/`}
                image={productImage(product.data.images[0]!)}
                imageAlt={product.data.description}
                price={product.data.price}
                loading={i < 3 ? 'eager' : 'lazy'}
              />
            ))}
          </div>
        </div>
      )
    }
  </main>
  <Footer />
</Base>

<style>
  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4) var(--space-3);
  }

  @media (min-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8) var(--space-6);
    }

    /* spec: list thumbnails ~340px tall on desktop */
    .product-grid :global(.product-card-media) {
      aspect-ratio: auto;
      height: 340px;
    }
  }

  /* ---- consultation variant (Wedding & Events) ---- */
  .consult {
    max-width: 920px;
    text-align: center;
  }

  .consult-media {
    max-height: 480px;
    overflow: hidden;
    background: var(--color-surface);
    margin-bottom: var(--space-7);
  }

  .consult-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* video keeps its native 16:9 — no crop */
  .consult-media--video {
    max-height: none;
  }

  .consult-media--video video {
    display: block;
    width: 100%;
    height: auto;
  }

  .consult-intro {
    max-width: 52ch;
    margin-inline: auto;
    color: var(--color-text-muted);
  }

  .how-steps {
    list-style: none;
    margin: var(--space-6) 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
    font-size: 14px;
  }

  .how-steps .roman {
    margin-right: var(--space-1);
  }
</style>
