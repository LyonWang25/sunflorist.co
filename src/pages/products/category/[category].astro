---
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import PageHead from '../../../components/PageHead.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { categories, type Category } from '../../../data/categories';
import { breadcrumbJsonLd } from '../../../data/jsonld';
import { productImage, siteImage } from '../../../utils/images';
import { getProducts } from '../../../utils/products';

export async function getStaticPaths() {
  return categories.map((cat) => ({ params: { category: cat.slug }, props: { cat } }));
}

interface Props {
  cat: Category;
}

const { cat } = Astro.props;
const products = cat.consultationOnly ? [] : await getProducts(cat.slug);

// consultation-variant process steps (illustrated)
const processSteps = [
  {
    image: 'process-01-meet.jpg',
    alt: 'Watercolor illustration of a florist and client chatting over a lookbook and coffee',
    numeral: 'i.',
    title: "Let's meet",
    text: 'We listen to your story, your vision and what matters most.',
  },
  {
    image: 'process-02-design.jpg',
    alt: 'Watercolor illustration of a sketchbook with a bouquet drawing, photos and color swatches',
    numeral: 'ii.',
    title: 'Plan & design',
    text: 'We create a custom design that reflects your style and the feeling you want to create.',
  },
  {
    image: 'process-03-style.jpg',
    alt: 'Watercolor illustration of a floral ceremony arch with drapery beside a lake',
    numeral: 'iii.',
    title: 'We style the day',
    text: 'We handle every detail so you can be fully present and enjoy every moment.',
  },
];

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Collections', path: '/products/' },
  { name: cat.name },
];
---

<Base
  title={`${cat.name} | Sun Florist`}
  description={`${cat.intro} Sun Florist — serving DC, MD, VA and NC.`}
  ogImage="/og/collections.jpg"
  jsonLd={breadcrumbJsonLd(crumbs)}
>
  <Nav current={cat.slug === 'wedding-events' ? 'weddings' : 'collections'} />
  <main>
    <PageHead {crumbs} title={cat.name} lede={cat.consultationOnly ? undefined : cat.intro} />

    {
      cat.consultationOnly ? (
        <div class="container consult">
          {
            cat.heroVideo && (
              <div class="consult-media consult-media--video">
                <video
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  poster={cat.heroVideo.poster}
                  width={cat.heroVideo.width}
                  height={cat.heroVideo.height}
                  aria-label={cat.coverAlt}
                >
                  <source src={cat.heroVideo.webm} type="video/webm" />
                  <source src={cat.heroVideo.mp4} type="video/mp4" />
                </video>
              </div>
            )
          }
          <p class="consult-intro">{cat.intro}</p>
          <div class="process-grid">
            {
              processSteps.map((step) => (
                <div class="process-step">
                  <Image
                    src={siteImage(step.image)}
                    widths={[240, 480]}
                    sizes="240px"
                    format="webp"
                    quality={80}
                    alt={step.alt}
                    loading="lazy"
                    decoding="async"
                  />
                  <h2>
                    <span class="roman">{step.numeral}</span> {step.title}
                  </h2>
                  <p>{step.text}</p>
                </div>
              ))
            }
          </div>
          <a class="btn" href="/contact/">
            Start a consultation
          </a>
        </div>
      ) : (
        <div class="container">
          <div class="product-grid">
            {products.map((product, i) => (
              <ProductCard
                name={product.data.name}
                href={`/products/${product.data.slug}/`}
                image={productImage(product.data.images[0]!)}
                imageAlt={product.data.description}
                price={product.data.price}
                loading={i < 3 ? 'eager' : 'lazy'}
              />
            ))}
          </div>
        </div>
      )
    }
  </main>
  <Footer />
</Base>

<style>
  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4) var(--space-3);
  }

  @media (min-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-8) var(--space-6);
    }

    /* spec: list thumbnails ~340px tall on desktop */
    .product-grid :global(.product-card-media) {
      aspect-ratio: auto;
      height: 340px;
    }
  }

  /* ---- consultation variant (Wedding & Events) ---- */
  .consult {
    max-width: 920px;
    text-align: center;
  }

  .consult-media {
    max-height: 480px;
    overflow: hidden;
    background: var(--color-surface);
    margin-bottom: var(--space-7);
  }

  .consult-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* video keeps its native 16:9 — no crop */
  .consult-media--video {
    max-height: none;
  }

  .consult-media--video video {
    display: block;
    width: 100%;
    height: auto;
  }

  .consult-intro {
    max-width: 52ch;
    margin-inline: auto;
    color: var(--color-text-muted);
  }

  /* illustrated process steps */
  .process-grid {
    display: grid;
    gap: var(--space-7);
    margin-block: var(--space-8);
  }

  .process-step :global(img) {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    object-fit: cover;
    margin-inline: auto;
    background: var(--color-surface);
  }

  .process-step h2 {
    font-size: 22px;
    font-weight: 600;
    margin-top: var(--space-4);
  }

  .process-step h2 .roman {
    font-size: 14px;
    margin-right: var(--space-1);
  }

  .process-step p {
    font-size: 14px;
    color: var(--color-text-muted);
    max-width: 30ch;
    margin: var(--space-2) auto 0;
  }

  @media (min-width: 768px) {
    .process-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
      align-items: start;
    }

    .process-step :global(img) {
      width: 220px;
      height: 220px;
    }
  }
</style>
