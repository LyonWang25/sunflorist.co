---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHead from '../components/PageHead.astro';
import ContactButtons from '../components/ContactButtons.astro';
import { site } from '../data/site';
import { breadcrumbJsonLd, floristJsonLd } from '../data/jsonld';
import { siteImage } from '../utils/images';

const crumbs = [{ name: 'Home', path: '/' }, { name: 'Contact' }];
const pickupLines = site.pickupLocations.map(
  (loc) => `${loc.street}, ${loc.city}, ${loc.region} ${loc.postalCode}`,
);
---

<Base
  title="Contact | Sun Florist"
  description={`Order flowers or start a wedding consultation — WhatsApp, WeChat, Instagram or phone. Pick up in ${site.pickupLocations.map((loc) => `${loc.city}, ${loc.region}`).join(' or ')}. Serving ${site.serviceAreaLong}; preserved florals ship US-wide.`}
  ogImage="/og/contact.jpg"
  jsonLd={[floristJsonLd(), breadcrumbJsonLd(crumbs)]}
>
  <Nav />
  <main>
    <PageHead {crumbs} title="Contact" lede="Message us — we reply the same day." />

    <div class="container contact-grid">
      <div class="contact-channels">
        <ContactButtons phone layout="grid" />

        <div class="qr-row" id="wechat">
          <figure>
            <Image
              src={siteImage('wechat-qr.jpg')}
              widths={[160, 320]}
              sizes="150px"
              format="webp"
              quality={80}
              alt={`WeChat QR code — scan to add ${site.wechatName}`}
              loading="lazy"
              decoding="async"
            />
            <figcaption>WeChat · {site.wechatName}</figcaption>
          </figure>
          <figure>
            <Image
              src={siteImage('whatsapp-qr.jpg')}
              widths={[160, 320]}
              sizes="150px"
              format="webp"
              quality={80}
              alt={`WhatsApp QR code — scan to message ${site.name}`}
              loading="lazy"
              decoding="async"
            />
            <figcaption>WhatsApp</figcaption>
          </figure>
        </div>

        <ul class="hairline-rows contact-info">
          <li>
            <span class="row-label">Pick up</span>
            <span class="pickup-list">
              {pickupLines.map((line) => <span>{line}</span>)}
            </span>
          </li>
          <li>
            <span class="row-label">Phone</span>
            <span class="tnum"><a href={site.phoneHref}>{site.phoneDisplay}</a></span>
          </li>
          <li><span class="row-label">Hours</span><span>{site.hours.label}</span></li>
          <li><span class="row-label">Serving</span><span>{site.serviceAreaShort}</span></li>
          <li><span class="row-label">Deliver</span><span>{site.delivery}</span></li>
        </ul>
      </div>

      <div class="contact-map">
        <iframe
          src={site.mapsEmbedUrl}
          title={`Map — ${site.name} location`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </div>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .contact-grid {
    display: grid;
    gap: var(--space-7);
    padding-top: var(--space-4);
  }

  .qr-row {
    display: flex;
    justify-content: center;
    gap: var(--space-7);
    margin-top: var(--space-6);
  }

  .qr-row figure {
    margin: 0;
    text-align: center;
  }

  .qr-row :global(img) {
    width: 150px;
    height: 150px;
    margin-inline: auto;
    border: 1px solid var(--color-divider);
    padding: var(--space-2);
    background: #ffffff;
  }

  .qr-row figcaption {
    margin-top: var(--space-2);
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .contact-info {
    margin-top: var(--space-6);
  }

  .contact-info li span:last-child {
    text-align: right;
  }

  .pickup-list {
    display: grid;
    gap: var(--space-1);
  }

  .contact-info a:hover {
    color: var(--color-accent-700);
  }

  .contact-map iframe {
    display: block;
    width: 100%;
    height: 240px;
    border: 0;
    background: var(--color-surface);
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
      align-items: start;
    }

    .contact-map iframe {
      height: 420px;
    }
  }
</style>
