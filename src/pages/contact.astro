---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PageHead from '../components/PageHead.astro';
import ContactButtons from '../components/ContactButtons.astro';
import { site } from '../data/site';
import { breadcrumbJsonLd, floristJsonLd } from '../data/jsonld';
import { siteImage } from '../utils/images';

const crumbs = [{ name: 'Home', path: '/' }, { name: 'Contact' }];
const addressLine = `${site.address.street}, ${site.address.city}, ${site.address.region}`;
---

<Base
  title="Contact | Sun Florist"
  description={`Order flowers or start a wedding consultation — WhatsApp, WeChat, Instagram or phone. Visit us at ${addressLine}. Serving ${site.serviceAreaLong}.`}
  ogImage="/og/contact.jpg"
  jsonLd={[floristJsonLd(), breadcrumbJsonLd(crumbs)]}
>
  <Nav />
  <main>
    <PageHead {crumbs} title="Contact" lede="Message us — we reply the same day." />

    <div class="container contact-grid">
      <div class="contact-channels">
        <ContactButtons phone layout="grid" />

        <div class="wechat-note" id="wechat">
          <p>
            WeChat: <strong>{site.wechatId}</strong>
          </p>
          <Image
            src={siteImage('wechat-qr.jpg')}
            widths={[160, 320]}
            sizes="140px"
            format="webp"
            quality={75}
            alt={`WeChat QR code for ${site.name}`}
            loading="lazy"
            decoding="async"
          />
        </div>

        <ul class="hairline-rows contact-info">
          <li><span class="row-label">Visit</span><span>{addressLine}</span></li>
          <li><span class="row-label">Phone</span><span class="tnum">{site.phoneDisplay}</span></li>
          <li><span class="row-label">Hours</span><span>{site.hours.label}</span></li>
          <li><span class="row-label">Serving</span><span>{site.serviceAreaShort}</span></li>
        </ul>
      </div>

      <div class="contact-map">
        <iframe
          src={site.mapsEmbedUrl}
          title={`Map — ${site.name} location`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </div>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .contact-grid {
    display: grid;
    gap: var(--space-7);
    padding-top: var(--space-4);
  }

  .wechat-note {
    margin-top: var(--space-5);
    text-align: center;
    font-size: 14px;
    color: var(--color-text-muted);
  }

  .wechat-note strong {
    color: var(--color-text);
  }

  .wechat-note :global(img) {
    width: 140px;
    height: 140px;
    margin: var(--space-2) auto 0;
    border: 1px solid var(--color-divider);
  }

  .contact-info {
    margin-top: var(--space-6);
  }

  .contact-info li span:last-child {
    text-align: right;
  }

  .contact-map iframe {
    display: block;
    width: 100%;
    height: 240px;
    border: 0;
    background: var(--color-surface);
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
      align-items: start;
    }

    .contact-map iframe {
      height: 420px;
    }
  }
</style>
