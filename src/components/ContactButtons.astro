---
import { site } from '../data/site';

interface Props {
  /** include the phone button (secondary style) */
  phone?: boolean;
  /** stack buttons full-width (mobile CTA style stays via CSS) */
  layout?: 'row' | 'grid';
}

const { phone = false, layout = 'row' } = Astro.props;
---

<div class:list={['contact-buttons', `contact-buttons--${layout}`]}>
  <a class="btn" href={site.whatsappHref}>WhatsApp</a>
  <a class="btn" href={site.wechatHref}>WeChat</a>
  <a class="btn" href={site.instagramHref}>Instagram</a>
  {phone && <a class="btn btn--secondary" href={site.phoneHref}>Call us</a>}
</div>

<style>
  .contact-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  @media (max-width: 767px) {
    .contact-buttons--grid {
      flex-direction: column;
    }

    .contact-buttons--grid .btn {
      width: 100%;
    }
  }

  @media (min-width: 768px) {
    .contact-buttons--grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
