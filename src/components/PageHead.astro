---
import Breadcrumbs from './Breadcrumbs.astro';
import type { Crumb } from '../data/jsonld';

interface Props {
  crumbs: Crumb[];
  title: string;
  lede?: string;
}

const { crumbs, title, lede } = Astro.props;
---

<div class="page-head container">
  <Breadcrumbs {crumbs} />
  <h1>{title}</h1>
  <hr class="gold-rule" />
  {lede && <p class="lede">{lede}</p>}
</div>
