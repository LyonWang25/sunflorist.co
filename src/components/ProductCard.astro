---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  href: string;
  image: ImageMetadata;
  imageAlt: string;
  price?: number;
  loading?: 'eager' | 'lazy';
}

const { name, href, image, imageAlt, price, loading = 'lazy' } = Astro.props;
---

<a class="product-card" {href}>
  <div class="product-card-media">
    <Image
      src={image}
      widths={[320, 480, 640]}
      sizes="(max-width: 767px) 50vw, (max-width: 1099px) 33vw, 400px"
      format="webp"
      quality={75}
      alt={imageAlt}
      {loading}
      decoding="async"
    />
  </div>
  <div class="product-card-row">
    <span class="product-card-name">{name}</span>
    {price !== undefined && <span class="product-card-price tnum">${price}</span>}
  </div>
</a>

<style>
  .product-card {
    display: block;
    color: var(--color-text);
  }

  .product-card-media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-surface);
  }

  .product-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-card-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .product-card-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 17px;
    line-height: 1.3;
  }

  .product-card-price {
    color: var(--color-accent-700);
    font-size: 14px;
    white-space: nowrap;
  }

  .product-card:hover .product-card-name {
    color: var(--color-accent-700);
  }

  @media (min-width: 768px) {
    .product-card-name {
      font-size: 20px;
    }
  }
</style>
