---
import Seo from '../components/Seo.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogType?: string;
  ogImage?: string;
  jsonLd?: object | object[];
  /** preload data for the page's single LCP image (hero / product main) */
  preloadImage?: {
    href: string;
    imagesrcset?: string;
    imagesizes?: string;
    type?: string;
  };
}

const { title, description, ogType, ogImage, jsonLd, preloadImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Lora:ital,wght@0,400;0,600;1,400&display=swap"
    />

    {
      preloadImage && (
        <link
          rel="preload"
          as="image"
          href={preloadImage.href}
          imagesrcset={preloadImage.imagesrcset}
          imagesizes={preloadImage.imagesizes}
          type={preloadImage.type}
          fetchpriority="high"
        />
      )
    }

    <Seo {title} {description} {ogType} {ogImage} {jsonLd} />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <script>
      // Blur-up fade-in (media-performance-spec §4). Containers with .blur-up
      // carry an inline low-res background; the sharp image fades in 200ms
      // after load. Without JS the image is simply visible from the start.
      document.querySelectorAll<HTMLElement>('.blur-up').forEach((wrap) => {
        const img = wrap.querySelector('img');
        if (!img) return;
        const reveal = () => wrap.classList.add('loaded');
        if (img.complete) reveal();
        else img.addEventListener('load', () => setTimeout(reveal, 200), { once: true });
      });

      // Device-aware chat CTAs: WhatsApp / WeChat deep links only make sense
      // where the app can open (phones/tablets). On desktop, point the
      // buttons at the contact page QR codes to scan instead.
      const canOpenChatApps =
        /Android|iPhone|iPod/i.test(navigator.userAgent) || navigator.maxTouchPoints > 1;
      if (!canOpenChatApps) {
        document
          .querySelectorAll<HTMLAnchorElement>('[data-chat-cta]')
          .forEach((link) => (link.href = '/contact/#wechat'));
      }
    </script>
  </body>
</html>
